{
  "name": "Containerlab DooD",
  "image": "ghcr.io/srl-labs/containerlab/devcontainer-dood-slim:0.72.0",
  "runArgs": [
    "--network=host",
    "--pid=host",
    "--privileged"
  ],

  "mounts": [
    "type=bind,source=/var/run/docker.sock,target=/var/run/docker.sock",
    "type=bind,source=/var/lib/docker,target=/var/lib/docker",
    "type=bind,source=${localEnv:HOME}/.kube,target=/root/.kube,readonly"
  ],

  "features": {
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    }
  },

  "workspaceFolder": "${localWorkspaceFolder}",
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
  
  "customizations": {
    "vscode": {
      "extensions": ["ms-azuretools.vscode-docker", "srl-labs.containerlab-utils", "bierner.markdown-mermaid", "anthropic.claude-code", "ms-kubernetes-tools.vscode-kubernetes-tools"]
    }
  },

  "postStartCommand": "sudo chmod 666 /var/run/docker.sock"
}